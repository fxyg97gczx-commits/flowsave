# Google AdSense (선택 — 없으면 데모 광고 표시)
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxx
# NEXT_PUBLIC_ADSENSE_SLOT_HOME_BANNER=1234567890
# NEXT_PUBLIC_ADSENSE_SLOT_HOME_NATIVE=1234567891
# NEXT_PUBLIC_ADSENSE_SLOT_LIST_NATIVE=1234567892
# NEXT_PUBLIC_ADSENSE_SLOT_REPORTS_BANNER=1234567893

# 배포 URL (선택)
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# 버그 리포트 (선택 — 설정 시 이메일/GitHub 링크 표시)
# NEXT_PUBLIC_BUG_REPORT_EMAIL=your@email.com
# NEXT_PUBLIC_BUG_REPORT_GITHUB_URL=https://github.com/you/flowsave/issues/new
